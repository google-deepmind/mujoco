<mujoco model="spherical_field_crossing">
  <compiler coordinate="local" inertiafromgeom="true"/>

  <option gravity="0 0 0" timestep="0.002"/>

  <extension>
    <plugin plugin="mujoco.magnet">
      <instance name="magnetic_environment">
        <config key="type" value="spherical_field"/>
        <config key="center" value="0.0 0.0 1.0"/>
        <config key="Bmax" value="1.0 1.0 1.0"/>
        <config key="radius" value="1.0"/>
      </instance>
    </plugin>
  </extension>

  <worldbody>
    <light pos="0 0 4" dir="0 0 -1"/>

    <geom name="floor" type="plane" size="5 5 0.1" rgba="0.8 0.8 0.8 1"/>

    <site name="field_center" pos="0 0 1" size="1.0" rgba="1 0 0 0.2"/>

    <body name="ball" pos="-0.5 0.0 1.3">
      <freejoint name="ball_free"/>
      <geom name="ball_geom" type="sphere" size="0.15" rgba="0.2 0.6 1 0.5"/>
      <plugin plugin="mujoco.magnet">
        <config key="type" value="induced_magnet"/>
        <config key="mu_r" value="1000"/>
        <config key="V" value="5e-6"/>
      </plugin>
    </body>
  </worldbody>

  <keyframe>
    <key name="initial_velocity" qpos="0 0 0 1 0 0 0" qvel="0 0 0 0 0 0"/>
  </keyframe>
</mujoco>
