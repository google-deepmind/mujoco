<mujoco model="stiction_grasp">
  <!-- DEMO: an antipodal (parallel-jaw) gripper pinching a box. A passive tendon pulls the two jaws
       together with a constant force, so friction alone must support the box's weight, with a healthy
       margin (mu*N is several times the weight: it SHOULD hold). Toggle "Stiction" in simulate's
       Option panel:
         ON  -> the box stays put in the grasp (real static friction).
         OFF -> the box slowly slips down out of the jaws (the soft-friction creep we fixed).
       impratio=0.2 softens friction so the slip is obvious within a couple of seconds. The amber line
       marks the box's starting bottom edge. Backspace to reset.                                      -->
  <option timestep="0.001" cone="elliptic" impratio="0.1">
    <flag stiction="enable"/>
  </option>

  <statistic extent="0.34" center="0 0 0.42" meansize="0.05"/>

  <visual>
    <headlight diffuse="0.35 0.35 0.4" ambient="0.18 0.18 0.22" specular="0.2 0.2 0.2"/>
    <rgba haze="0.06 0.07 0.09 1"/>
    <map fogstart="2" fogend="6" shadowclip="1.2"/>
    <quality shadowsize="8192" offsamples="8"/>
    <global azimuth="120" elevation="-14" offwidth="1920" offheight="1080"/>
    <scale jointlength="0.08" jointwidth="0.008"/>
  </visual>

  <asset>
    <texture name="skybox" type="skybox" builtin="gradient"
             rgb1="0.16 0.20 0.26" rgb2="0.03 0.035 0.05" width="512" height="512"/>
    <texture name="floortex" type="2d" builtin="checker" mark="edge" markrgb="0.10 0.11 0.13"
             rgb1="0.14 0.15 0.18" rgb2="0.10 0.11 0.14" width="512" height="512"/>
    <material name="floor" texture="floortex" texrepeat="14 14" reflectance="0.18"
              shininess="0.3" specular="0.4"/>
    <texture name="boxtex" type="cube" builtin="checker" mark="cross" markrgb="1 1 1"
             rgb1="0.86 0.42 0.20" rgb2="0.74 0.33 0.16" width="256" height="256"/>
    <material name="box" texture="boxtex" texuniform="true" texrepeat="2 2"
              reflectance="0.08" shininess="0.4" specular="0.5"/>
    <material name="metal" rgba="0.52 0.57 0.64 1" reflectance="0.35" shininess="0.85" specular="0.9"/>
    <material name="rubber" rgba="0.10 0.11 0.13 1" reflectance="0.02" shininess="0.1" specular="0.1"/>
    <material name="mount" rgba="0.24 0.27 0.32 1" reflectance="0.15" shininess="0.5" specular="0.5"/>
    <material name="line" rgba="0.96 0.78 0.22 1" emission="0.35"/>
  </asset>

  <worldbody>
    <light pos="0.4 -0.7 1.6" dir="-0.25 0.45 -1" diffuse="0.8 0.78 0.72" specular="0.5 0.5 0.5"
           castshadow="true"/>
    <light pos="-0.8 -0.3 1.0" dir="0.8 0.3 -1" diffuse="0.25 0.28 0.34" castshadow="false"/>
    <geom name="floor" type="plane" size="3 3 .1" pos="0 0 -0.15" material="floor"/>

    <!-- gripper mount + palm (cosmetic, no collisions) -->
    <geom type="box" pos="0 0 0.62" size="0.018 0.05 0.06" material="metal"
          contype="0" conaffinity="0"/>
    <geom type="box" pos="0 0 0.55" size="0.11 0.045 0.018" material="mount"
          contype="0" conaffinity="0"/>

    <!-- fixed reference line at the box's starting bottom edge -->
    <geom name="startline" type="box" size="0.17 0.0035 0.0016" pos="0 0.07 0.35"
          material="line" contype="0" conaffinity="0"/>

    <body name="box" pos="0 0 0.4">
      <freejoint/>
      <geom type="box" size="0.05 0.05 0.05" mass="1" friction="1 0.005 0.0001" material="box"/>
    </body>

    <body name="padL" pos="-0.07 0 0.4">
      <joint name="jL" type="slide" axis="1 0 0"/>
      <!-- rubber gripping pad (functional collision surface) -->
      <geom type="box" size="0.018 0.058 0.07" mass="0.2" friction="1 0.005 0.0001"
            material="rubber"/>
      <!-- cosmetic metal finger + knuckle reaching up to the palm -->
      <geom type="box" pos="-0.026 0 0.0" size="0.012 0.05 0.075" material="metal"
            contype="0" conaffinity="0"/>
      <geom type="box" pos="-0.026 0 0.105" size="0.012 0.04 0.04" material="metal"
            contype="0" conaffinity="0"/>
      <site name="sL" pos="0 0 0" size="0.006"/>
    </body>

    <body name="padR" pos="0.07 0 0.4">
      <joint name="jR" type="slide" axis="1 0 0"/>
      <geom type="box" size="0.018 0.058 0.07" mass="0.2" friction="1 0.005 0.0001"
            material="rubber"/>
      <geom type="box" pos="0.026 0 0.0" size="0.012 0.05 0.075" material="metal"
            contype="0" conaffinity="0"/>
      <geom type="box" pos="0.026 0 0.105" size="0.012 0.04 0.04" material="metal"
            contype="0" conaffinity="0"/>
      <site name="sR" pos="0 0 0" size="0.006"/>
    </body>
  </worldbody>

  <tendon>
    <!-- passive spring tendon pulling the jaws together: tension = stiffness*(length - springlength).
         the box holds the jaw centers ~0.136 apart, so tension ~= 1000*(0.136-0.116) ~ 20 N each. -->
    <spatial stiffness="1000" springlength="0.116" width="0.0035" rgba="0.35 0.72 0.45 1">
      <site site="sL"/>
      <site site="sR"/>
    </spatial>
  </tendon>
</mujoco>
